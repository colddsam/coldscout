# ── Vite Dashboard (React) ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_API_KEY=your_fastapi_api_key_here
VITE_SITE_NAME="Cold Scout"

# ── Supabase Auth ────────────────────────────────────────────────────────────
# Get these from your Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Base URL used for OAuth and email confirmation callbacks.
# Must match the URL your browser uses to access the app AND must be present in
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs.
#   Development:  http://localhost:5173
#   Production:   https://your-production-domain.com
VITE_APP_URL=http://localhost:5173

# ── Proxy Server (Node.js) ────────────────────────────────────────────────
PORT=3001
API_BASE_URL=http://127.0.0.1:8000
API_KEY=your_fastapi_api_key_here
