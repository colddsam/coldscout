# =============================================================================
# AI Lead Generation System — Environment Variables
# Copy this file to .env and fill in your specific values.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=your_secret_key_here
API_KEY=your_api_key_here
APP_URL=https://your-app-url.com
IMAGE_BASE_URL=https://your-cdn.com/path/to/logo.png
PRODUCTION_STATUS=RUN

# ── Database (PostgreSQL via Supabase) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
# 🔴 NOT ACTIVE — Redis is not used in the current scheduler approach.
# Provide a value here only if reactivating Celery (see docker-compose.yml).
REDIS_URL=

# ── Google Places API ────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── AI / LLM (Groq) ─────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Email (Brevo SMTP) ──────────────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_user@smtp-brevo.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_password_here
FROM_EMAIL=your_sender_email@domain.com
FROM_NAME="Your Sender Name"
REPLY_TO_EMAIL=your_reply_email@domain.com

# ── IMAP (Reply Polling) ────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password_here

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin_email@domain.com

# ── Notifications (Telegram) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Notifications (WhatsApp via CallMeBot) ───────────────────────────────────
WHATSAPP_NUMBER=+91XXXXXXXXXX
CALLMEBOT_API_KEY=your-callmebot-key

# ── Scheduling (IST hours for APScheduler cron jobs) ─────────────────────────
DISCOVERY_HOUR=6
QUALIFICATION_HOUR=7
PERSONALIZATION_HOUR=8
OUTREACH_HOUR=9
REPORT_HOUR=23
REPORT_MINUTE=30
EMAIL_SEND_INTERVAL_SECONDS=360

# ── Branding (Optional) ─────────────────────────────────────────────────────
BOOKING_LINK=https://calendly.com/your-link
SENDER_ADDRESS=Your City, Your Country
