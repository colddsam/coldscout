# =============================================================================
# AI Lead Generation System — Environment Variables
# Copy this file to .env and fill in your specific values.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=generate_a_secure_random_string
API_KEY=your_secure_api_key_for_backend
SECURITY_SALT=generate_a_secure_random_salt
APP_URL=https://your-app-url.onrender.com
IMAGE_BASE_URL=https://your-cdn.com/logo.png
PRODUCTION_STATUS=RUN  # Set to HOLD to pause the pipeline
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://localleadpro-dashboard.vercel.app
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Admin & Security ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@domain.com
INITIAL_ADMIN_PASSWORD=your_secure_password
VITE_API_KEY=your_secure_api_key_for_backend  # MUST MATCH API_KEY ABOVE
VITE_SITE_NAME="Local Lead Pro"               # Branding for Dashboard

# ── Database (PostgreSQL via Supabase) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:port/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here  # From Supabase Dashboard → Settings → API → JWT Secret

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# 🔴 OPTIONAL — Only required if reactivating Celery.
REDIS_URL=

# ── Google Places API ────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza_your_google_key

# ── AI / LLM (Groq) ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.1-8b-instant

# ── Email (Brevo SMTP via Outreach) ──────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_user
BREVO_SMTP_PASSWORD=your_brevo_smtp_password
FROM_EMAIL=sender@domain.com
FROM_NAME="Lead Gen System"
REPLY_TO_EMAIL=replies@domain.com
# Shared secret for Brevo webhook authentication (recommended in production).
# Set the same value in your Brevo webhook configuration under "Custom headers".
# Leave empty to disable validation (development only).
BREVO_WEBHOOK_SECRET=

# ── IMAP (Gmail Reply Polling) ─────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_16char_app_password

# ── Alerts & Automation ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id_from_userinfobot
WHATSAPP_NUMBER=+91XXXXXXXXXX
CALLMEBOT_API_KEY=your-callmebot-key
CRON_JOB_API_KEY=your_cronjob_org_api_key
RENDER_DEPLOY_HOOK=https://api.render.com/deploy/srv-...

# ── Scheduling (IST Hours) ───────────────────────────────────────────────────
DISCOVERY_HOUR=6
QUALIFICATION_HOUR=7
PERSONALIZATION_HOUR=8
OUTREACH_HOUR=9
REPORT_HOUR=23
REPORT_MINUTE=30
EMAIL_SEND_INTERVAL_SECONDS=360

# ── International Discovery Configuration ────────────────────────────────────
# Comma-separated ISO 3166-1 alpha-2 country codes to focus on.
# Leave empty for worldwide discovery (diverse markets).
DISCOVERY_COUNTRY_FOCUS=
# Number of location-category targets per daily discovery run (default: 4)
DISCOVERY_TARGET_COUNT=4
# Location hierarchy depth: "country", "region", "city", or "sub_area" (default: sub_area)
DISCOVERY_DEPTH=sub_area
# Max Google Places pagination pages per search, 1-3 (default: 3 = up to 60 results)
DISCOVERY_MAX_PAGES=3

# ── Branding & Outreach ───────────────────────────────────────────────────
BOOKING_LINK=https://calendly.com/your-business-link
SENDER_ADDRESS="Your City, Your Country"

# ── Meta Threads Lead Generation ──────────────────────────────────────────
# 1. Create a Meta Developer App at https://developers.facebook.com/
# 2. Request `threads_keyword_search` permission via App Review (2-4 weeks)
# 3. Complete OAuth flow to get a long-lived token
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=https://your-app-url.onrender.com/api/v1/threads/oauth/callback
THREADS_DAILY_REPLY_CAP=20
THREADS_REPLY_COOLDOWN_HOURS=24
THREADS_MIN_FOLLOWERS_FILTER=50
THREADS_ENABLED=false  # Set to true after Threads API review is approved

# Razorpay Payment Gateway
# Obtain from Razorpay Dashboard → Settings → API Keys
# Use test keys (rzp_test_...) in development, live keys (rzp_live_...) in production
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

